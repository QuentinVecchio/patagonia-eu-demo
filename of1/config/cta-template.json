{
  "html": "<div style=\"background-color:#27455C;padding:60px 32px;text-align:center;font-family:'Ridgeway Sans',system-ui,sans-serif;\"><h2 style=\"color:#F5F0E0;font-size:34px;font-weight:500;line-height:1.1;letter-spacing:-0.02em;margin:0 0 16px 0;\">{{title}}</h2><p style=\"color:rgba(255,255,255,0.75);font-size:16px;line-height:1.5;max-width:500px;margin:0 auto 28px auto;\">{{description}}</p><a href=\"{{href}}\" style=\"display:inline-block;background-color:#ffffff;color:#000000;padding:12px 24px;font-size:14px;font-weight:500;text-decoration:none;border-radius:0px;font-family:'Ridgeway Sans',system-ui,sans-serif;\">{{buttonText}}</a></div>",
  "slots": ["title", "description", "buttonText"],
  "fallback": {
    "title": "Find gear that lasts a lifetime",
    "description": "Explore jackets and layers built for the mountains and the planet.",
    "buttonText": "Explore Now"
  }
}
